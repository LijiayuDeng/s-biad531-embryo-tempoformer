# ====== Paths (edit for your machine) ======
# processed npy dirs
PROC_28C5=/ABS/PATH/TO/processed_28C5
PROC_25C=/ABS/PATH/TO/processed_25C

# split jsons (format: {"train":[...],"val":[...],"test":[...]})
SPLIT_28C5=/ABS/PATH/TO/split/28C5.json
SPLIT_25C=/ABS/PATH/TO/split/25C.json

# checkpoints for 4 ablations
CKPT_CNN_SINGLE=/ABS/PATH/TO/best_cnn_single.pt
CKPT_MEANPOOL=/ABS/PATH/TO/best_meanpool.pt
CKPT_NOCONS=/ABS/PATH/TO/best_nocons.pt
CKPT_FULL=/ABS/PATH/TO/best_full.pt

# output root (relative to repo ok)
RUNS_DIR=./runs

# ====== Constants ======
DT_H=0.25
T0_HPF=4.5
CLIP_LEN=24
IMG_SIZE=384
EXPECT_T=192
STRIDE=8

# ====== Runtime ======
DEVICE=auto
AMP=1
USE_EMA=1
BATCH_SIZE=64
