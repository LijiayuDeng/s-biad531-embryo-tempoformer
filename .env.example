# ====== Paths (edit for your machine) ======
# processed npy dirs
PROC_28C5=/ABS/PATH/TO/processed_28C5
PROC_25C=/ABS/PATH/TO/processed_25C

# split jsons (format: {"train":[...],"val":[...],"test":[...]})
SPLIT_28C5=/ABS/PATH/TO/split/28C5.json
SPLIT_25C=/ABS/PATH/TO/split/25C.json

# optional external-domain import (S-BIAD840 Princeton PNG export)
SBIAD840_SRC_ROOT=/ABS/PATH/TO/s-biad840/Files/Princeton_Data
SBIAD840_OUT_ROOT=./data/sbiad840_aligned_4p5
PROC_28C5_SBIAD840=./data/sbiad840_aligned_4p5/processed_28C5_sbiad840
PROC_25C_SBIAD840=./data/sbiad840_aligned_4p5/processed_25C_sbiad840
SPLIT_28C5_SBIAD840=./data/sbiad840_aligned_4p5/splits/28C5_sbiad840_test.json
SPLIT_25C_SBIAD840=./data/sbiad840_aligned_4p5/splits/25C_sbiad840_test.json

# checkpoints for 4 ablations
CKPT_CNN_SINGLE=/ABS/PATH/TO/best_cnn_single.pt
CKPT_MEANPOOL=/ABS/PATH/TO/best_meanpool.pt
CKPT_NOCONS=/ABS/PATH/TO/best_nocons.pt
CKPT_FULL=/ABS/PATH/TO/best_full.pt

# output root (relative to repo ok)
RUNS_DIR=./runs

# optional interpreter override for shell entrypoints
PYTHON_BIN=python3

# ====== Constants ======
DT_H=0.25
T0_HPF=4.5
CLIP_LEN=24
IMG_SIZE=384
EXPECT_T=192
STRIDE=8

# ====== Runtime ======
DEVICE=auto
AMP=1
USE_EMA=1
BATCH_SIZE=64
